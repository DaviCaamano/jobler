{
	"manifest_version": 3,
	"name": "jobler",
	"version": "0.0.0",
	"description": "Job Crawler that reads your LinkedIn, Ziprecruiter, and Indeed search results, runs them through your filters, and turns what remains into an excel sheet.",
	"icons": {
			"16": "assets/icons/logo/logo 16.png",
			"32": "assets/icons/logo/logo 32.png",
			"48": "assets/icons/logo/logo 48.png",
			"128": "assets/icons/logo/logo 128.png"
	},
	"action": {
		"default_popup": "dist/menu.html",
		"default_icon": "assets/icons/logo/logo 16.png"
	},
	"background": {
		"service_worker": "dist/background.js",
		"type": "module"
	},
	"content_scripts": [
		{
		  "matches": ["https://www.linkedin.com/*"],
		  "js": ["dist/content.js"]
		}
	]
}
