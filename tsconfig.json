{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "lib": ["ES2022", "DOM"],
        "types": ["chrome", "vite/client"],
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@backgrounds/*": ["src/backgrounds/*"],
            "@components/*": ["src/components/*"],
            "@constants/*": ["src/constants/*"],
            "@contents/*": ["src/contents/*"],
            "@hooks/*": ["src/hooks/*"],
            "@interfaces/*": ["src/interfaces/*"],
            "@styles/*": ["src/styles/*"],
            "@utils/*": ["src/utils/*"],
            "#icons/*": ["assets/icons/*"],
            "@/*": ["src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.content.ts", "vite.config.main.ts"]
}
