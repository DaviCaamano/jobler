{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "lib": ["ES2022", "DOM"],
        "types": ["chrome", "vite/client"],
        "jsx": "react-jsx",
        "paths": {
            "@*": ["src/*"],
            "#*": ["assets/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
