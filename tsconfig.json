{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "skipLibCheck": true,
        "strict": true,
        "lib": ["ES2022", "DOM"],
        "types": ["chrome", "vite/client", "node"],
        "jsx": "react-jsx",
        "paths": {
            "@backgrounds/*": ["./src/backgrounds/*"],
            "@components/*": ["./src/components/*"],
            "@constants/*": ["./src/constants/*"],
            "@contents/*": ["./src/contents/*"],
            "@hooks/*": ["./src/hooks/*"],
            "@interfaces/*": ["./src/interfaces/*"],
            "@stores/*": ["./src/stores/*"],
            "@styles/*": ["./src/styles/*"],
            "@utils/*": ["./src/utils/*"],
            "#icons/*": ["../assets/icons/*"],
            "#/*": ["./assets/icons/*"],
            "#logos/*": ["../assets/logos/*"],
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "./src/**/*.ts",
        "./src/**/*.tsx",
        "env.d.ts",
        "manifest.config.ts",
        "vite.config.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
